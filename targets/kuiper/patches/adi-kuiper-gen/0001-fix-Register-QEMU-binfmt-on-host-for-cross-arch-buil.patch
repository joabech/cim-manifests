From 2ec0601031ba72d66d372c2dd1add737d9c197e3 Mon Sep 17 00:00:00 2001
From: Joakim Bech <Joakim.Bech@analog.com>
Date: Tue, 5 May 2026 14:53:43 +0200
Subject: [PATCH] fix: Register QEMU binfmt on host for cross-arch builds

The build was completing with exit code 0 but producing no image because:
1. QEMU binfmt_misc was not registered on the host kernel, causing
   debootstrap's second stage to fail with "Exec format error"
2. The container-side update-binfmts silently failed (modern Docker
   doesn't allow writing to /proc/sys/fs/binfmt_misc from containers)
3. Without -e on the outer bash, failures didn't propagate

Fix by registering binfmt on the host via multiarch/qemu-user-static
before starting the build container, and adding -e to the container's
bash invocation for proper error propagation.
---
 build-docker.sh            | 7 ++++++-
 stages/01.bootstrap/run.sh | 7 +++++--
 2 files changed, 11 insertions(+), 3 deletions(-)

diff --git a/build-docker.sh b/build-docker.sh
index 31fa041..3c2541e 100755
--- a/build-docker.sh
+++ b/build-docker.sh
@@ -34,6 +34,11 @@ if [[ ! ${DEBIAN_VERSION} = bookworm && ! ${DEBIAN_VERSION} = bullseye && ! ${DE
 	exit 1
 fi
 
+# Ensure QEMU binfmt is registered on the host for ARM cross-architecture builds
+if [ ! -f /proc/sys/fs/binfmt_misc/qemu-arm ]; then
+	docker run --rm --privileged multiarch/qemu-user-static --reset -p yes
+fi
+
 # Build docker image
 docker build --build-arg BASE_IMAGE="${BASE_IMAGE}" -t ${IMAGE_NAME} .
 
@@ -49,7 +54,7 @@ docker run -t --privileged \
 			-v ./kuiper-volume:/kuiper-volume \
 			-e "DEBIAN_VERSION="${DEBIAN_VERSION}"" \
 			--name ${CONTAINER_NAME} ${IMAGE_NAME} \
-			/bin/bash -o pipefail -c "bash kuiper-stages.sh"
+			/bin/bash -eo pipefail -c "bash kuiper-stages.sh"
 
 if [ $PRESERVE_CONTAINER = n ]; then
 	# Remove image, container and corresponding volume
diff --git a/stages/01.bootstrap/run.sh b/stages/01.bootstrap/run.sh
index 6bb6b64..a9aa2f2 100644
--- a/stages/01.bootstrap/run.sh
+++ b/stages/01.bootstrap/run.sh
@@ -7,14 +7,17 @@
 # Author: Larisa Radu <larisa.radu@analog.com>
 
 if [[ "$(uname -m)" != "aarch64" && "$(uname -m)" != "arm*" ]]; then
-	update-binfmts --enable qemu-arm
+	update-binfmts --enable qemu-arm 2>/dev/null || true
 fi
 
 mkdir "${BUILD_DIR}"
 debootstrap --arch=${TARGET_ARCHITECTURE} \
 			--components "main,non-free,non-free-firmware" \
 			--include=ca-certificates,curl,gnupg,wget \
-			--keyring "/usr/share/keyrings/debian-archive-"${DEBIAN_VERSION}"-stable.gpg" "${DEBIAN_VERSION}" "${BUILD_DIR}"
+			--keyring "/usr/share/keyrings/debian-archive-"${DEBIAN_VERSION}"-stable.gpg" "${DEBIAN_VERSION}" "${BUILD_DIR}" || {
+	echo "ERROR: debootstrap failed to create rootfs in ${BUILD_DIR}"
+	exit 1
+}
 
 if [[ "$(uname -m)" != "aarch64" && "$(uname -m)" != "arm*" ]]; then
 	cp /usr/bin/qemu-arm-static "${BUILD_DIR}"/usr/bin
-- 
2.53.0

