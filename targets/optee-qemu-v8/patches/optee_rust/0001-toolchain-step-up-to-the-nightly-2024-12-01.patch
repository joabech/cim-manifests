From 353eb8bf2bbf80befadbff160fca298d034a236a Mon Sep 17 00:00:00 2001
From: Joakim Bech <joakim.bech@gmail.com>
Date: Fri, 20 Feb 2026 16:03:55 +0100
Subject: [PATCH] toolchain: step up to the nightly-2024-12-01

This fixed a couple of compiler issues seen when running with different
rust compiler versions.

Signed-off-by: Joakim Bech <joakim.bech@gmail.com>
---
 rust-toolchain.toml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/rust-toolchain.toml b/rust-toolchain.toml
index a2b17a9..baacc78 100644
--- a/rust-toolchain.toml
+++ b/rust-toolchain.toml
@@ -18,7 +18,7 @@
 # Toolchain override for rustup
 
 [toolchain]
-channel = "nightly-2024-05-15"
+channel = "nightly-2024-12-01"
 components = [ "rust-src", "rustfmt", "clippy" ]
 targets = ["aarch64-unknown-linux-gnu", "arm-unknown-linux-gnueabihf"]
 # minimal profile: install rustc, cargo, and rust-std
-- 
2.53.0

