From 8d2c173f0e2e82eabcd571d9c271cfb0c19412d5 Mon Sep 17 00:00:00 2001
From: Joakim Bech <joakim.bech@gmail.com>
Date: Thu, 19 Feb 2026 18:51:55 +0100
Subject: [PATCH] br: make_def_config: escape %% in argparse help string

Fixes ValueError when using Python 3.14+ due to argparse interpreting
%TOP_DIR% as format specifiers.

Signed-off-by: Joakim Bech <joakim.bech@gmail.com>
---
 br-ext/scripts/make_def_config.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/br-ext/scripts/make_def_config.py b/br-ext/scripts/make_def_config.py
index 4fc6666..8b27f61 100644
--- a/br-ext/scripts/make_def_config.py
+++ b/br-ext/scripts/make_def_config.py
@@ -14,7 +14,7 @@ def get_args():
     parser.add_argument('--out', required=True,
                         help='Path to buildroot out directory')
     parser.add_argument('--top-dir', required=True,
-                        help='Replaces %TOP_DIR% in defconfig files')
+                        help='Replaces %%TOP_DIR%% in defconfig files')
     parser.add_argument('--br-ext-optee', required=True,
                         help='Path the OP-TEE external buildroot tree')
     parser.add_argument('--br-defconfig', required=True, action='append',
-- 
2.53.0

