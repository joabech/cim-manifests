From 9c28bebca4a6a7d12c06b3e343c9cb71728017c5 Mon Sep 17 00:00:00 2001
From: Joakim Bech <Joakim.Bech@analog.com>
Date: Tue, 10 Feb 2026 20:13:26 +0100
Subject: [PATCH 5/6] Fix sign-compare warnings in peripheral drivers

Added explicit casts to resolve signed/unsigned comparison warnings in:
- I2C, FLC, UART, RTC, HPB, and CLCD peripheral drivers

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 Libraries/PeriphDrivers/Source/CLCD/clcd_reva.c | 2 +-
 Libraries/PeriphDrivers/Source/FLC/flc_me10.c   | 2 +-
 Libraries/PeriphDrivers/Source/HPB/hpb_reva.c   | 2 +-
 Libraries/PeriphDrivers/Source/I2C/i2c_reva.c   | 6 +++---
 Libraries/PeriphDrivers/Source/RTC/rtc_reva.c   | 2 +-
 Libraries/PeriphDrivers/Source/UART/uart_reva.c | 2 +-
 6 files changed, 8 insertions(+), 8 deletions(-)

diff --git a/Libraries/PeriphDrivers/Source/CLCD/clcd_reva.c b/Libraries/PeriphDrivers/Source/CLCD/clcd_reva.c
index b51fa4de20..6e2d946fa7 100644
--- a/Libraries/PeriphDrivers/Source/CLCD/clcd_reva.c
+++ b/Libraries/PeriphDrivers/Source/CLCD/clcd_reva.c
@@ -89,7 +89,7 @@ int MXC_CLCD_RevA_ConfigPanel(mxc_clcd_reva_regs_t *clcd, mxc_clcd_cfg_t *cfg)
 
     clcd->ctrl |= cfg->bpp;
 
-    for (i = 0; i < cfg->paletteSize; i++) {
+    for (i = 0; i < (int)cfg->paletteSize; i++) {
         clcd->palette[i] = cfg->palette[i];
     }
     return E_NO_ERROR;
diff --git a/Libraries/PeriphDrivers/Source/FLC/flc_me10.c b/Libraries/PeriphDrivers/Source/FLC/flc_me10.c
index 5e09569352..b247c5b78d 100644
--- a/Libraries/PeriphDrivers/Source/FLC/flc_me10.c
+++ b/Libraries/PeriphDrivers/Source/FLC/flc_me10.c
@@ -133,7 +133,7 @@ int MXC_FLC_PageErase(uint32_t address)
 // *****************************************************************************
 void MXC_FLC_Read(int address, void *buffer, int len)
 {
-    if (address < MXC_FLASH_MEM_BASE || address >= (MXC_FLASH_MEM_BASE + MXC_FLASH_MEM_SIZE)) {
+    if ((unsigned long)address < MXC_FLASH_MEM_BASE || (unsigned long)address >= (MXC_FLASH_MEM_BASE + MXC_FLASH_MEM_SIZE)) {
         return;
     }
     MXC_FLC_Com_Read(address, buffer, len);
diff --git a/Libraries/PeriphDrivers/Source/HPB/hpb_reva.c b/Libraries/PeriphDrivers/Source/HPB/hpb_reva.c
index 0d1fc3c93d..329b309d65 100644
--- a/Libraries/PeriphDrivers/Source/HPB/hpb_reva.c
+++ b/Libraries/PeriphDrivers/Source/HPB/hpb_reva.c
@@ -56,7 +56,7 @@ static void MXC_HPB_RevA_ConfigMem(mxc_hpb_reva_regs_t *hpb, const mxc_hpb_mem_c
                          (mem->latency_cycle << MXC_F_HPB_REVA_MEMTIM_LAT_POS);
 
     // Send configuration commands
-    for (i = 0; i < mem->cfg_reg_val_len; i++) {
+    for (i = 0; i < (int)mem->cfg_reg_val_len; i++) {
         if (mem->device_type == (mxc_hpb_device_t)MXC_HPB_REVA_DEV_XCCELA_PSRAM) {
             MXC_HPB_RegWrite8(&(mem->cfg_reg_val[i]), mem->base_addr, index);
         } else {
diff --git a/Libraries/PeriphDrivers/Source/I2C/i2c_reva.c b/Libraries/PeriphDrivers/Source/I2C/i2c_reva.c
index 801093b862..c0160ad571 100644
--- a/Libraries/PeriphDrivers/Source/I2C/i2c_reva.c
+++ b/Libraries/PeriphDrivers/Source/I2C/i2c_reva.c
@@ -111,7 +111,7 @@ int MXC_I2C_RevA_SetSlaveAddr(mxc_i2c_reva_regs_t *i2c, unsigned int slaveAddr,
         return E_NULL_PTR;
     }
 
-    if (idx >= (sizeof(i2c->slave_multi) / sizeof(uint32_t))) {
+    if ((unsigned)idx >= (sizeof(i2c->slave_multi) / sizeof(uint32_t))) {
         return E_NOT_SUPPORTED;
     }
 
@@ -456,11 +456,11 @@ int MXC_I2C_RevA_DMA_SetRequestSelect(mxc_i2c_reva_regs_t *i2c, mxc_dma_reva_reg
     rxChannel = states[i2cNum].channelRx;
 
     // This function will overwrite the current DMA TX/RX Request Selects.
-    if (txReqSel != -1) {
+    if (txReqSel != (uint32_t)-1) {
         MXC_SETFIELD(dma->ch[txChannel].ctrl, MXC_F_DMA_REVA_CTRL_REQUEST, txReqSel);
     }
 
-    if (rxReqSel != -1) {
+    if (rxReqSel != (uint32_t)-1) {
         MXC_SETFIELD(dma->ch[rxChannel].ctrl, MXC_F_DMA_REVA_CTRL_REQUEST, rxReqSel);
     }
 
diff --git a/Libraries/PeriphDrivers/Source/RTC/rtc_reva.c b/Libraries/PeriphDrivers/Source/RTC/rtc_reva.c
index 48ff3ac891..b3b19fcbfe 100644
--- a/Libraries/PeriphDrivers/Source/RTC/rtc_reva.c
+++ b/Libraries/PeriphDrivers/Source/RTC/rtc_reva.c
@@ -375,7 +375,7 @@ int MXC_RTC_RevA_GetTime(mxc_rtc_reva_regs_t *rtc, uint32_t *sec, uint32_t *subs
         *sec = MXC_RTC_RevA_GetSecond(rtc);
 
         // Repeat until a steady state is reached.
-    } while (temp_sec != *sec);
+    } while ((int32_t)temp_sec != *sec);
 
     return E_NO_ERROR;
 }
diff --git a/Libraries/PeriphDrivers/Source/UART/uart_reva.c b/Libraries/PeriphDrivers/Source/UART/uart_reva.c
index aced3fcf17..0fe8e3eb26 100644
--- a/Libraries/PeriphDrivers/Source/UART/uart_reva.c
+++ b/Libraries/PeriphDrivers/Source/UART/uart_reva.c
@@ -401,7 +401,7 @@ int MXC_UART_RevA_SetClockSource(mxc_uart_reva_regs_t *uart, int usePCLK)
     }
     if (usePCLK) {
         MXC_SETFIELD(uart->ctrl, MXC_F_UART_REVA_CTRL_CLKSEL, 0 << MXC_F_UART_REVA_CTRL_CLKSEL_POS);
-        if (baudRate > PeripheralClock / 8) {
+        if ((int)baudRate > (int)(PeripheralClock / 8)) {
             baudRate = PeripheralClock / 8;
         }
     } else {
-- 
