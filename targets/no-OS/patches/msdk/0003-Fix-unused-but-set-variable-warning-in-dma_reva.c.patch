From fe450db38b8f81fc3de9906853f9254d47993b3f Mon Sep 17 00:00:00 2001
From: Joakim Bech <Joakim.Bech@analog.com>
Date: Tue, 10 Feb 2026 19:55:14 +0100
Subject: [PATCH 3/6] Fix unused-but-set-variable warning in dma_reva.c

Added (void)dma_idx cast in the else branch to suppress the warning when
TARGET_NUM != 32665. The variable is set but not used in this configuration.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 Libraries/PeriphDrivers/Source/DMA/dma_reva.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/Libraries/PeriphDrivers/Source/DMA/dma_reva.c b/Libraries/PeriphDrivers/Source/DMA/dma_reva.c
index 0aa44504c2..1616f7592e 100644
--- a/Libraries/PeriphDrivers/Source/DMA/dma_reva.c
+++ b/Libraries/PeriphDrivers/Source/DMA/dma_reva.c
@@ -69,6 +69,7 @@ int MXC_DMA_RevA_Init(mxc_dma_reva_regs_t *dma)
     numCh = MXC_DMA_CH_OFFSET;
     offset = numCh * dma_idx;
 #else
+    (void)dma_idx;
     numCh = MXC_DMA_CHANNELS;
     offset = 0;
 #endif
@@ -434,6 +435,7 @@ void MXC_DMA_RevA_Handler(mxc_dma_reva_regs_t *dma)
     numCh = MXC_DMA_CH_OFFSET;
     offset = numCh * dma_idx;
 #else
+    (void)dma_idx;
     numCh = MXC_DMA_CHANNELS;
     offset = 0;
 #endif
-- 
