From 3afac33e69e3e86f88f202fb0e44a2ec597b8297 Mon Sep 17 00:00:00 2001
From: Joakim Bech <Joakim.Bech@analog.com>
Date: Fri, 6 Feb 2026 17:55:45 +0100
Subject: [PATCH] PeriphDrivers: Add missing mxc_delay and mxc_lock sources for
 MAX32650

Add mxc_delay.c and mxc_lock.c to MAX32650 peripheral driver build
files. These source files provide essential system functions
(MXC_Delay, MXC_DelayAsync, MXC_DelayHandler, MXC_GetLock,
MXC_FreeLock) that are referenced by other peripheral drivers
(DMA, SPI, SYS) but were missing from the build, causing
undefined reference errors during linking.

Signed-off-by: Joakim Bech <Joakim.Bech@analog.com>
---
 Libraries/PeriphDrivers/max32650_files.mk | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/Libraries/PeriphDrivers/max32650_files.mk b/Libraries/PeriphDrivers/max32650_files.mk
index 93eb9ebdf8..8356c9c480 100644
--- a/Libraries/PeriphDrivers/max32650_files.mk
+++ b/Libraries/PeriphDrivers/max32650_files.mk
@@ -52,6 +52,8 @@ PINS_FILE ?= $(SOURCE_DIR)/SYS/pins_me10.c
 # Source files
 PERIPH_DRIVER_C_FILES += $(PINS_FILE)
 PERIPH_DRIVER_C_FILES += $(SOURCE_DIR)/SYS/sys_me10.c
+PERIPH_DRIVER_C_FILES += $(SOURCE_DIR)/SYS/mxc_delay.c
+PERIPH_DRIVER_C_FILES += $(SOURCE_DIR)/SYS/mxc_lock.c
 
 PERIPH_DRIVER_INCLUDE_DIR += $(SOURCE_DIR)/ADC
 PERIPH_DRIVER_C_FILES += $(SOURCE_DIR)/ADC/adc_me10.c
-- 
