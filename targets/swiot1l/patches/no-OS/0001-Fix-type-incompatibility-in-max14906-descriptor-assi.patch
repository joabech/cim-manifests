From 358b406b0ae0c0aba245aeeb4f59baeeeee9f263 Mon Sep 17 00:00:00 2001
From: Joakim Bech <Joakim.Bech@analog.com>
Date: Fri, 19 Dec 2025 14:01:14 +0100
Subject: [PATCH 1/4] Fix type incompatibility in max14906 descriptor
 assignment

GCC 14 enforces stricter type checking for pointer assignments. The assignment
of max14906_iio_desc to swiot_iio_desc->max14906 requires explicit casting to
the expected struct max149x6_iio_desc * type.

- Added explicit cast: (struct max149x6_iio_desc *)
- Resolves compilation error with GCC 14.3

Signed-off-by: Joakim Bech <Joakim.Bech@analog.com>
---
 projects/swiot1l/src/swiot_fw.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/projects/swiot1l/src/swiot_fw.c b/projects/swiot1l/src/swiot_fw.c
index 9afdd4810..072acfa8d 100644
--- a/projects/swiot1l/src/swiot_fw.c
+++ b/projects/swiot1l/src/swiot_fw.c
@@ -301,7 +301,7 @@ int swiot_firmware()
 		}
 
 		swiot_iio_desc->ad74413r = ad74413r_iio_desc;
-		swiot_iio_desc->max14906 = max14906_iio_desc;
+		swiot_iio_desc->max14906 = (struct max149x6_iio_desc *)max14906_iio_desc;
 		swiot_iio_desc->mode = SWIOT_RUNTIME;
 
 		app_init_param.devices = iio_devices;
-- 
2.43.0

